# --- Database -------------------------------------------------------------
# Local dev: started by `pnpm --filter @uos-poker/server db:dev` (embedded PG 17 on :5433).
# Railway: use the Postgres plugin's DATABASE_URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/uospoker?schema=public

# --- Server ----------------------------------------------------------------
PORT=3001
NODE_ENV=development
SITE_URL=http://localhost:5173

# --- Auth (Better Auth) ------------------------------------------------------
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001

# Google OAuth (Cloud Console -> OAuth client, web application)
# Authorised redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (Resend) ----------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=UOS Poker <noreply@yourdomain.example>

# --- Ops ---------------------------------------------------------------------
# The account that signs up with this email is auto-promoted to admin.
ADMIN_EMAIL=
